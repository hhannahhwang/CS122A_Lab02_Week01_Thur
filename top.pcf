# iCESugar v1.5

set_io clk 35
set_frequency clk 12

# 7-Seg Display (Pmod2)

set_io seg7[0] 37  # a
set_io seg7[1] 38  # b
set_io seg7[2] 39  # c
set_io seg7[3] 40  # d
set_io seg7[4] 41  # e
set_io seg7[5] 42  # f
set_io seg7[6] 46  # g
set_io seg7[7] 36  # dp

# DIP Switches (Pmod3)

set_io val1[0] 34
set_io val1[1] 32
set_io val1[2] 31
set_io val1[3] 28

set_io val2[0] 27
set_io val2[1] 26
set_io val2[2] 25
set_io val2[3] 23
